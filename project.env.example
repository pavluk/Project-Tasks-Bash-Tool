# Required: package name used in archive file names
PROJECT_NAME=mod_example

# Required: release version
PROJECT_VERSION=1.2.3

# Optional: npm scripts to run before prepareRelease replacements
# Format: comma-separated list
# Example: PROJECT_NPM=build_prod,build_dev
PROJECT_NPM=build_prod,build_dev

# Optional: directory where package.json is located
# Default: build
# Can be relative (from project root) or absolute
PROJECT_NPM_DIR=build

# Optional aliases supported by script:
# NAME=mod_example
# VERSION=1.2.3
# NPM_SCRIPT=build_prod,build_dev
# NPM_DIR=build
